# Onderhoudsmodus: op Vercel production staat die standaard aan; preview/dev standaard uit.
# Op productie uitzetten: MAINTENANCE_ENABLED=false
# Lokaal met next start (production build): MAINTENANCE_ENABLED=false
# MAINTENANCE_ENABLED=false

# Instagram (optioneel – standaard: trcar_detail)
# NEXT_PUBLIC_INSTAGRAM_HANDLE=trcar_detail

# Automatisch 3 laatste posts (Instagram Graph API) – server-only, geen NEXT_PUBLIC_
# INSTAGRAM_ACCESS_TOKEN=...
# INSTAGRAM_USER_ID=...

# Fallback: shortcodes voor "Laatste posts" (komma-gescheiden). Zie docs/INSTAGRAM.md
# NEXT_PUBLIC_INSTAGRAM_POST_SHORTCODES=ABC123,DEF456,GHI789

# Review-aanvraag na afspraak (cron). Zie docs/REVIEW-REQUESTS.md
# CRON_SECRET=een-geheime-string-voor-cron-beveiliging
# Redis (Vercel KV / Upstash) – wordt door Vercel gezet na toevoegen Redis-integratie
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
# Optioneel: link in review-mail (standaard https://trcardetail.be)
# NEXT_PUBLIC_SITE_URL=https://trcardetail.be

# Optioneel: eigen OSRM-router-URL voor kilometerberekening langs de weg (eindigt vóór /route/…)
# Standaard: publieke demo router.project-osrm.org
# OSRM_ROUTE_BASE_URL=https://router.project-osrm.org
